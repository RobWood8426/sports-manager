# Template for local dev env. COMMITTED -- copy to .env and fill in real values.
# .env is gitignored. The service account JSON lives at .secrets/firebase-sa.json
# (also gitignored) -- it is a file, not an inline value.

# --- XTDB ---
SM_ENV=                               # set to "production" to use RocksDB; leave blank for in-memory dev
SM_XTDB_DATA_DIR=data/xtdb            # RocksDB data directory (prod only)

# --- Firebase (server-side) ---
# App-specific name so it won't collide with a machine-wide GOOGLE_APPLICATION_CREDENTIALS.
SM_FIREBASE_CREDENTIALS=./.secrets/firebase-sa.json
FIREBASE_PROJECT_ID=

# --- Firebase web app config (public; rendered into the sign-in page) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=

# --- Session cookie signing (generate a random 32+ char secret) ---
SM_SESSION_SECRET=

# --- Public base URL (used in QR codes and email links) ---
SM_BASE_URL=http://localhost:3000
